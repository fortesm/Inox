Module Std.Math

== Inox 0.1 mathematical surface.
==
== This module is intentionally clean-room. It does not copy or translate any
== third-party runtime library. Some elementary Float functions are compiler
== prelude intrinsics lowered to LLVM/libm by the current backend:
==
==   Abs(Float), Sqrt, Cbrt, Sin, Cos, Tan, ArcSin, ArcCos, ArcTan,
==   ArcTan2, Sinh, Cosh, Tanh, Exp, Ln, LnXP1, Log2, Log10, LogN,
==   Power, Floor, Ceil, FMod, Hypot, Hypot3,
==   RadToDeg, DegToRad, RadToGrad, GradToRad, RadToCycle, CycleToRad.
==
== Integer helpers below are implemented in Inox source and are part of the
== first non-toy Std.Math layer.

Min(A Integer, B Integer) Integer :
    Result Integer := B

    if A < B
        Result := A
    ;

    Return Result
;

Max(A Integer, B Integer) Integer :
    Result Integer := B

    if A > B
        Result := A
    ;

    Return Result
;

Clamp(X Integer, MinValue Integer, MaxValue Integer) Integer :
    Result Integer := X

    if Result < MinValue
        Result := MinValue
    ;

    if Result > MaxValue
        Result := MaxValue
    ;

    Return Result
;

EnsureRange(X Integer, MinValue Integer, MaxValue Integer) Integer :
    Return Clamp(X, MinValue, MaxValue)
;

InRange(X Integer, MinValue Integer, MaxValue Integer) Bool :
    Return (X >= MinValue) and (X <= MaxValue)
;

Sign(X Integer) Integer :
    if X < 0
        Return -1
    elif X > 0
        Return 1
    else
        Return 0
    ;
;

IsEven(X Integer) Bool :
    Return (X mod 2) = 0
;

IsOdd(X Integer) Bool :
    Return (X mod 2) # 0
;

Sqr(X Integer) Integer :
    Return X * X
;

Cube(X Integer) Integer :
    Return X * X * X
;

Gcd(A Integer, B Integer) Integer :
    X Integer := Abs(A)
    Y Integer := Abs(B)
    T Integer := 0

    while Y # 0
        T := X mod Y
        X := Y
        Y := T
    ;

    Return X
;

Lcm(A Integer, B Integer) Integer :
    Result Integer := 0

    if (A # 0) and (B # 0)
        Result := (Abs(A) div Gcd(A, B)) * Abs(B)
    ;

    Return Result
;

== Float convenience functions implemented in Inox source over backend math
== intrinsics. They deliberately use Float/Float64, not Currency/Crypto.
==
== KNOWN BACKLOG (see INOX_CANONICAL conformance gaps):
==  - Lcm/Sqr/Cube can overflow Int64 for large inputs. Per ADR-0006 overflow
==    must trap, but checking-mode arithmetic traps are not implemented yet, so
==    today these wrap silently. Audit them when checking mode lands.
==  - Pi/Tau/E are written as zero-argument functions (not Const) because the
==    backend does not yet lower a Float `Const` to IR. Revisit as `Const` once
==    Float constant lowering exists. The literals are given to Float64's honest
==    precision (~16-17 significant digits); extra digits would be decorative.

Pi Float :
    Return 3.141592653589793
;

Tau Float :
    Return 6.283185307179586
;

E Float :
    Return 2.718281828459045
;

Cotan(X Float) Float :
    Return 1.0 / Tan(X)
;

Cot(X Float) Float :
    Return Cotan(X)
;

Secant(X Float) Float :
    Return 1.0 / Cos(X)
;

Sec(X Float) Float :
    Return Secant(X)
;

Cosecant(X Float) Float :
    Return 1.0 / Sin(X)
;

Csc(X Float) Float :
    Return Cosecant(X)
;

Coth(X Float) Float :
    Return 1.0 / Tanh(X)
;

Sech(X Float) Float :
    Return 1.0 / Cosh(X)
;

Csch(X Float) Float :
    Return 1.0 / Sinh(X)
;

Log(X Float) Float :
    Return Ln(X)
;

LogBase(Base Float, X Float) Float :
    Return LogN(Base, X)
;
