Module RepeatUntil

Main() :
    var I := 3
    var Total := 0

    repeat
        Total := Total + I
        I := I - 1
        until I = 0
    ;

    repeat
        until I = 0
        break
    ;

    repeat
        I := I + 1
        until I = 1
        I := I - 1
        break
    ;

    repeat
        break
    ;
;
