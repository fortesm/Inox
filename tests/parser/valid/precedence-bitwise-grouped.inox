== Mixed bitwise families are allowed WHEN explicitly parenthesized.

Module PrecedenceBitwiseGrouped

Main :
    A := 12
    B := 10
    C := 6
    R1 := (A bitand B) bitor C
    R2 := A bitand B bitand C
    R3 := (A bitand B) shl C
    PutLn(R1)
;
