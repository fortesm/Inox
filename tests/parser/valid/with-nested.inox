== CANON-11: nested 'with' — '.Member' always binds the innermost 'with' target.

Module ParserValidWithNested

Type
    TPoint Struct
        FX Integer
        FY Integer
    ;

Main :
    Var
        A TPoint
        B TPoint
    ;

    with A
        .FX := 1
        with B
            .FX := 10
            .FY := 20
        ;
        .FY := 2
    ;
;
