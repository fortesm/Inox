== CANON-11: unprefixed names inside 'with' body follow normal scope rules.

Module ParserValidWithScope

Type
    TRect Struct
        Width Integer
        Height Integer
    ;

Main :
    Var
        R TRect
        Scale Integer := 3
    ;

    with R
        .Width := Scale * 2
        .Height := Scale * 4
    ;
;
