Module NoEmptyParentheses

Type
    TAccount Struct
        FBalance Integer
    ;

Report :
;

Value Integer :
    Return 42
;

TAccount.Print(Self) :
;

Main :
    Var
        Account TAccount
    ;

    Report
    PutLn(Value)
    Account.Print
;
