== Mixed and/or is allowed WHEN explicitly parenthesized (canonical Layer A).

Module PrecedenceLogicalGrouped

Main :
    A := True
    B := False
    C := True
    R1 := A or (B and C)
    R2 := (A or B) and C
    R3 := A and B and C
    R4 := A or B or C
    PutLn(R1)
;
