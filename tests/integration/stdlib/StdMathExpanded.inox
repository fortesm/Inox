Module StdMathExpanded

Use Std.Core
Use Std.Math
Use Std.IO

Main :
    PutLn(Sign(-42))
    PutLn(Sign(0))
    PutLn(Sign(42))
    PutLn(EnsureRange(150, 0, 100))
    PutLn(InRange(50, 0, 100))
    PutLn(Sqr(12))
    PutLn(Cube(5))
    PutLn(Gcd(54, 24))
    PutLn(Lcm(21, 6))
    PutLn(2 ^ 10)

    PutLn(Sqrt(81.0))
    PutLn(Sin(0.0))
    PutLn(Cos(0.0))
    PutLn(Tan(0.0))
    PutLn(Power(2.0, 8.0))
    PutLn(Log10(1000.0))
    PutLn(Log2(1024.0))
    PutLn(Hypot(3.0, 4.0))
    PutLn(DegToRad(180.0))
    PutLn(RadToDeg(Pi))
    PutLn(Cotan(1.0))
    PutLn(Secant(0.0))
    PutLn(Cosecant(1.5707963267948966))
;
