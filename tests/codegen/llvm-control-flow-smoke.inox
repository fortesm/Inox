Module CodegenControlFlowSmoke

Compute(N Integer) Integer :
    Var
        Total Integer := 0
    ;

    for I in 1..N
        if I = 2
            continue
        ;

        Total := Total + I

        if Total > 10
            break
        ;
    ;

    Return Total
;

Main() :
    PutLn(Compute(5))
;
