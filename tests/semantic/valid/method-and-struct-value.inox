Module SemanticMethodStruct

Type
    TCounter Struct
        FValue Integer
    ;

TCounter.Add(Self mut, X Integer) :
    Self.FValue := Self.FValue + X
;

Read(C TCounter) Integer :
    Return C.FValue
;

Main :
    Var
        C TCounter
    ;

    C.Add(5)
    PutLn(Read(C))
;
