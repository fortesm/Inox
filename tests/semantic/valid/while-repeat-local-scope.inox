Module WhileRepeatLocalScope

Main :
    I Integer := 0

    while I < 1
        LocalWhile Integer := I + 1
        I := LocalWhile
    ;

    repeat
        LocalRepeat Integer := I
        I := LocalRepeat + 1
        until I > 1
    ;
;
