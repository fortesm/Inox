Module GroupedLocalDeclarations

Type
    TPoint Struct
        FX Integer
        FY Integer
    ;

Single :
    A Integer := 1
    PutLn(A)
;

Pair :
    A, B Integer := 1
    PutLn(A, B)
;

Many :
    A, B,C, D, E Integer := 1
    PutLn(A, B, C, D, E)
;

Booleans :
    X, Y Bool := true
    if X and Y
        PutLn("true")
    ;
;

Strings :
    S1, S2 String := "ok"
    PutLn(S1, S2)
;

Structs :
    P1, P2 TPoint
    P1.FX := 1
    P2.FY := P1.FX
;

Main :
    Single
    Pair
    Many
    Booleans
    Strings
    Structs
;
